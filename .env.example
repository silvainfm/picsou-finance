# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=picsou
POSTGRES_USER=picsou
POSTGRES_PASSWORD=change_me_strong_password_here

# ─── JWT ─────────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 48
JWT_SECRET=replace_with_64_char_base64_encoded_random_key_openssl_rand_base64_48

# ─── App credentials (single user) ───────────────────────────────────────────
APP_USERNAME=admin
# Generate bcrypt hash (cost 12):
#   htpasswd -bnBC 12 "" your_password | tr -d ':\n'
APP_PASSWORD_HASH=$2a$12$REPLACE_THIS_WITH_REAL_BCRYPT_HASH

# ─── CORS ────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173

# ─── Enable Banking (open banking sync) ──────────────────────────────────────
# Register free at https://enablebanking.com/ → Dashboard → Applications
# Supports Revolut, BoursoBank, Trade Republic and 2000+ EU banks (PSD2/OAuth)
ENABLEBANKING_APPLICATION_ID=
ENABLEBANKING_KEY_ID=
ENABLEBANKING_REDIRECT_URI=http://localhost:5173/sync/callback
# Private key in PKCS8 PEM format, with \n escaped as literal \n for env var:
# Generate: openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out private.pem
# Then upload the matching public key in Enable Banking dashboard.
# Paste the content of private.pem here, replacing actual newlines with \n:
ENABLEBANKING_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nMIIEvQ...your_key_here...\n-----END PRIVATE KEY-----

# ─── Trade Republic (optional, for direct WebSocket sync) ────────────────────
# Phone number in international format, PIN as string.
# Leave empty to use CSV import fallback only.
# WARNING: these are real credentials — never commit filled-in values to git.
TR_PHONE_NUMBER=
TR_PIN=

# ─── Spring profile ──────────────────────────────────────────────────────────
SPRING_PROFILES_ACTIVE=prod
